# Local environment for the punkrockai.com tooling.
# Copy to `.env` and fill in real values. .env is gitignored.

# Required by scripts/ingest-slides.mjs
SLIDES_SRC=/absolute/path/to/your/slide/source/folder

# Cloudflare R2 (S3-compatible) — required to upload hi-res originals.
# All five must be set for a real run, or pass --dry-run / --skip-upload.
# See scripts/README.md for how to mint these from the Cloudflare dashboard.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=punkrockai-slides
# Public URL prefix for the bucket. Either the auto-generated r2.dev domain
# (Settings → Public Access on the bucket) or a custom domain you've bound.
R2_PUBLIC_BASE=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev

# Number of upload retry attempts on transient failure (default 3).
# R2_MAX_RETRIES=3

# Set to 1 to skip the R2 upload step (still writes /site/public/images/slides/).
# Equivalent to passing `--skip-upload` on the command line.
# SKIP_UPLOAD=1

# Set to 1 for a no-op preview of what ingest will do.
# Equivalent to passing `--dry-run` on the command line.
# DRY_RUN=1

# ---------------------------------------------------------------------------
# Worker secrets (NOT used by the static site — set with `wrangler secret put`
# from inside the relevant worker/ directory). Listed here for reference.
# ---------------------------------------------------------------------------

# worker/pattern-finder
# ANTHROPIC_API_KEY=

# worker/submissions (Cloudflare Worker fallback)
# NOTION_TOKEN=

# ---------------------------------------------------------------------------
# Vercel serverless function — /api/submissions (Release Day submission portal)
# Notion integration token: workspace Settings → Connections → Develop
# DB ID: 32-char hex from the Notion DB share URL
# Set both in Vercel project settings → Environment Variables (all envs)
# ---------------------------------------------------------------------------
# NOTION_TOKEN=
# NOTION_DB_ID=

# ---------------------------------------------------------------------------
# Vercel serverless function — /api/subscribe (Beehiiv newsletter signup)
# API key: https://app.beehiiv.com/settings/integrations/api
# Publication ID: run `curl -H "Authorization: Bearer $BEEHIIV_API_KEY" \
#   https://api.beehiiv.com/v2/publications | jq '.data[].id'`
# Set both in Vercel project settings → Environment Variables (all envs)
# ---------------------------------------------------------------------------
# BEEHIIV_API_KEY=
# BEEHIIV_PUB_ID=

# Optional R2 base for per-slide audio (mp3 hosting). When set,
# build-audio-cues.mjs populates audio-cues.json with mp3Urls.
# R2_PUBLIC_BASE already covers this — same env var as slide imagery.

# ---------------------------------------------------------------------------
# ElevenLabs (per-slide TTS via scripts/generate-cues.mjs)
# Get an API key:   https://elevenlabs.io/app/settings/api-keys
# Pick a voice:     https://elevenlabs.io/app/voice-library  (copy the voice ID)
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional overrides (defaults: eleven_multilingual_v2 / mp3_44100_128)
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# Where the deployed site serves the cue mp3s from. Defaults to /audio/cues
# (i.e. site/public/audio/cues served at the same origin). Override if you
# upload to R2 / a CDN.
# AUDIO_PUBLIC_BASE=https://punkrockai-audio.your-subdomain.r2.dev/cues
